# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# env files (never upload secrets)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma (auto-generated)
app/generated/prisma

# misc
.DS_Store
*.pem

# debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# editor settings
.vscode/
.idea/

# MCP config (contains bearer tokens — keep off git)
.mcp.json

# Internal technical debt notes (not for public repo)
TECH_DEBT.md

# AI context files — the .txt philosophy/context files ARE committed (they must
# ship to production for the AI prompts to load); anything else here stays local.
/ai-context/*
!/ai-context/*.txt
