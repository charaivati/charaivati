model Collaboration {
  id           String   @id @default(cuid())
  requesterId  String
  /// Page-to-page collab — set when the receiver is a Page (delivery partners, suppliers, external collaborators)
  receiverPageId   String?
  /// Page-to-user collab — set when the receiver is a User (employees, personal team members)
  receiverUserId   String?
  /// "delivery_partner" | "supplier" | "employee" | "marketing" | "other"
  role         String
  /// "pending" | "accepted" | "rejected" | "cancelled"
  status       String   @default("pending")
  message      String?
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
  /// "team" | "third_party" | "partner"
  scope        String   @default("partner")
  initiativeId String?
  /// "founder" | "co_founder" | "ceo" | "partner" | "employee" | "custom"
  teamRole     String?
  customRole   String?
  /// Delivery cost structure — at most one should be set per collaboration
  costPerOrder     Float?  // flat fee per order regardless of size
  costPerKg        Float?  // fee per kg of total order weight
  costPerKgPerKm   Float?  // fee per kg per km of delivery distance
  costPerItemPerKm Float?  // fee per item per km of delivery distance
  receiverPage  Page?                  @relation("CollabReceiver", fields: [receiverPageId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  receiverUser  User?                  @relation("CollabReceiverUser", fields: [receiverUserId], references: [id], onDelete: Cascade)
  requester     Page                   @relation("CollabRequester", fields: [requesterId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  stepAssignees WorkflowStepAssignee[]

  @@unique([requesterId, receiverPageId, role])
  @@unique([requesterId, receiverUserId, role])
  @@index([requesterId])
  @@index([receiverPageId])
  @@index([receiverUserId])
  @@index([status])
}

