generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_PRISMA_URL")
  directUrl  = env("DATABASE_URL")
  extensions = [uuid_ossp(map: "uuid-ossp", schema: "extensions")]
}

/// ----------------------
/// Existing application models (kept & slightly extended)
/// ----------------------
model User {
  id                      String               @id @default(cuid())
  email                   String?              @unique
  phone                   String?              @unique
  passwordHash            String?
  verified                Boolean              @default(false)
  emailVerified           Boolean              @default(false)
  avatarUrl               String?
  avatarStorageKey        String?
  status                  String               @default("active")
  deletionScheduledAt     DateTime?
  tokenVersion            Int                  @default(0)
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  avatarAt                DateTime?
  name                    String?
  selectedCountry         String?
  lastSelectedLocalAreaId Int?
  shortBio                String?
  title                   String?
  preferredLanguage       String?              @default("en")
  contactVerified         Boolean              @default(false)
  mustChangePassword      Boolean              @default(false)
  createdByAdminId        String?
  discoverable            Boolean              @default(true)
  addresses               Address[]
  aiGoals                 AiGoal[]
  billingProfiles         BillingProfile[]
  businessIdeas           BusinessIdea[]       @relation("UserBusinessIdeas")
  cartItems               CartItem[]
  chatConvsA              ChatConversation[]   @relation("ChatConvA")
  chatConvsB              ChatConversation[]   @relation("ChatConvB")
  sentMessages            ChatMessage[]        @relation("ChatSender")
  msgBackups              ChatMessageBackup[]  @relation("UserMsgBackups")
  courseProgress          CourseProgress[]
  customTabs              CustomTab[]          @relation("UserCustomTabs")
  embeddings              Embedding[]          @relation("UserEmbeddings")
  events                  Event[]              @relation("UserEvents")
  expertSubscriptions     ExpertSubscription[]
  circles                 FriendCircle[]       @relation("UserCircles")
  circleMemberships       FriendCircleMember[] @relation("CircleMemberships")
  requestsReceived        FriendRequest[]      @relation("req_receiver")
  requestsSent            FriendRequest[]      @relation("req_sender")
  friendshipsA            Friendship[]         @relation("friendA")
  friendshipsB            Friendship[]         @relation("friendB")
  blocksMade              UserBlock[]          @relation("UserBlocksMade")
  blocksReceived          UserBlock[]          @relation("UserBlocksReceived")
  magicLinks              MagicLink[]
  orders                  Order[]
  pages                   Page[]               @relation("UserPages")
  pageFollows             PageFollow[]
  pinnedStores            PinnedStore[]
  posts                   Post[]               @relation("UserPosts")
  productRatings          ProductRating[]
  profile                 Profile?
  projectTimelines        ProjectTimeline[]
  proposals               Proposal[]           @relation("UserProposals")
  reviews                 Review[]             @relation("UserReviews")
  savedTagSets            SavedTagSet[]
  stores                  Store[]
  publicKey               UserPublicKey?
  userTabs                UserTab[]            @relation("UserUserTabs")
  verificationTokens      VerificationToken[]
  votes                   Vote[]               @relation("UserVotes")
  wishlistItems           WishlistItem[]
  communityBoardRoles     CommunityBoardMember[]
  communityMemberships    CommunityMembership[]  @relation("UserMemberships")
  healthBookings          HealthBooking[]
  notifications           Notification[]
  receivedCollaborations  Collaboration[]  @relation("CollabReceiverUser")
  assignedOrders          Order[]          @relation("OrderAssignedUser")
  companionProfile        UserCompanionProfile?
  sentInvites             Invite[]             @relation("InviteSender")
  todos                   Todo[]
  consultSession          ConsultSession?
  personalityProfile      PersonalityProfile?
  requestBroadcasts       RequestBroadcast[]   @relation("UserRequestBroadcasts")
  requestResponses        RequestResponse[]    @relation("UserRequestResponses")
  providerPresence        ProviderPresence?
  homeUnitId              String?
  homeUnitChangedAt       DateTime?
  homeUnit                Unit?                @relation("UserHomeUnit", fields: [homeUnitId], references: [id])
  issuesAuthored          Issue[]              @relation("UserIssues")
  issueSupports           IssueSupport[]       @relation("UserIssueSupports")
  issueConfirmations      IssueConfirmation[]  @relation("UserIssueConfirmations")

  @@index([email])
  @@index([phone])
  @@index([homeUnitId])
}

/// *
/// * Friend request (pending -> accepted/rejected)
model FriendRequest {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  message    String?
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  receiver   User     @relation("req_receiver", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User     @relation("req_sender", fields: [senderId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([senderId])
  @@index([receiverId])
}

/// *
/// * Mutual friendship (canonical ordering enforced by application code)
model Friendship {
  id        String   @id @default(cuid())
  userAId   String
  userBId   String
  createdAt DateTime @default(now())
  userA     User     @relation("friendA", fields: [userAId], references: [id], onDelete: Cascade)
  userB     User     @relation("friendB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
}

/// *
/// * One-directional block (A blocks B) with bilateral effect — see
/// * ACTION-INTENT-6: B can no longer see/contact A either. Separate from
/// * Friendship since a block can target a non-friend and must persist
/// * without a friendship existing. Blocking auto-unfriends the pair.
model UserBlock {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())
  blocker   User     @relation("UserBlocksMade", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("UserBlocksReceived", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

/// *
/// * Friend circles — named groups of friends (e.g. Family, Close Friends, custom)
model FriendCircle {
  id        String               @id @default(cuid())
  ownerId   String
  label     String
  color     String               @default("blue")
  isDefault Boolean              @default(false)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  owner     User                 @relation("UserCircles", fields: [ownerId], references: [id], onDelete: Cascade)
  members   FriendCircleMember[]

  @@index([ownerId])
}

/// *
/// * Members inside a friend circle
model FriendCircleMember {
  id       String       @id @default(cuid())
  circleId String
  userId   String
  addedAt  DateTime     @default(now())
  circle   FriendCircle @relation(fields: [circleId], references: [id], onDelete: Cascade)
  user     User         @relation("CircleMemberships", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([circleId, userId])
  @@index([circleId])
  @@index([userId])
}

/// *
/// * User profile / health
model Profile {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  heightCm               Int?
  weightKg               Float?
  stepsToday             Int?     @default(0)
  sleepHours             Float?
  waterLitres            Float?
  displayName            String?
  bio                    String?
  socialHandles          Json?
  topics                 Json?
  streakDays             Int?     @default(0)
  learningNotes          String?
  businesses             Json?
  weeklyEarningsEstimate Float?
  desiredMonthlyIncome   Float?   @default(0)
  preferredPayment       String?
  /// UPI VPA payment handle for non-store providers (REQBCAST-1b) — supersedes
  /// the unwired `preferredPayment`. Display/handoff only; shape-validated, never
  /// resolution-checked. Platform never collects.
  upiVpa                 String?
  /// SelfTab — purpose layer
  /// Legacy single drive (kept for backward compat)
  drive                  String?
  /// GoalEntry[] — flat array with driveId on each entry
  /// Shape: [{ id, driveId, statement, horizon, skills: [...], linkedBusinessIds, saved }]
  goals                  Json?
  /// HealthProfile — stored as JSON
  /// Shape: { food, exercise, sessionsPerWeek, heightCm, weightKg, age }
  /// Note: heightCm / weightKg here are string inputs from the form;
  /// the scalar heightCm / weightKg columns above are the validated numeric store.
  health                 Json?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  /// Cached AI roadmap — { phases: Phase[], suggestions: Suggestion[] }
  aiPlan                 Json?
  /// Selected drives — DriveType[] e.g. ["learning", "building"]
  drives                 Json?
  /// General skills — SkillEntry[] — abilities that apply across all goals
  generalSkills          Json?
  /// EnvironmentProfile — city, workspace, constraints, etc.
  environmentProfile     Json?
  /// FundsProfile — income sources, monthly burn, runway target
  fundsProfile           Json?
  /// WeekSchedule — { slots: TimeSlot[], tasks: Task[] }
  weekSchedule           Json?
  /// CHAKRA-1: per-chakra 1–7 self-report slider, e.g. { root: 5, sacral: 3, ... }
  chakraSelfReport       Json?
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MagicLink {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  type      String
  expiresAt DateTime
  used      Boolean   @default(false)
  createdAt DateTime  @default(now())
  usedAt    DateTime?
  ip        String?
  meta      Json?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([userId])
}

model Page {
  id                String             @id @default(cuid())
  ownerId           String?
  title             String
  description       String?
  avatarUrl         String?
  avatarStorageKey  String?
  status            String             @default("active")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  type              String             @default("standard")
  viewCount         Int                @default(0)
  pageType          String             @default("store")
  /// Soft-delete marker — set when the owner deletes the venture. null = active.
  deletedAt         DateTime?
  collaborationsIn  Collaboration[]    @relation("CollabReceiver")
  collaborationsOut Collaboration[]    @relation("CollabRequester")
  course            Course?
  healthBusiness    HealthBusiness?
  helpingInitiative HelpingInitiative?
  communityGroup    CommunityGroup?
  healthServices    HealthService[]
  healthBookings    HealthBooking[]
  owner             User?              @relation("UserPages", fields: [ownerId], references: [id])
  followers         PageFollow[]
  transfers         InitiativeTransfer[]

  @@index([ownerId])
}

model Course {
  id             String   @id @default(cuid())
  pageId         String   @unique
  courseType     String   @default("skill")
  dominantAspect String   @default("mental")
  aspectWeights  Json     @default("{\"mental\": 34, \"physical\": 33, \"emotional\": 33}")
  aspectBenefits Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  courseTags     String[] @default([])
  page           Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
}

/// Universal Store page models (products/videos/services)
model Store {
  id                String           @id @default(cuid())
  name              String
  description       String?
  ownerId           String
  createdAt         DateTime         @default(now())
  pageId            String?          @unique
  slug              String?          @unique
  deliveryFee       Float?
  freeDeliveryAbove Float?
  acceptingOrders   Boolean          @default(false)
  hoursText         String?
  /// Canonical store location (GEO-STORE-1) — replaces the owner-default-Address proxy
  line1             String?
  city              String?
  state             String?
  pincode           String?
  lat               Float?
  lng               Float?
  /// Soft-delete marker — set when the owner deletes the venture. null = active.
  deletedAt         DateTime?
  /// UPI VPA payment handle (REQBCAST-1b) — DISPLAY/HANDOFF ONLY. Platform never
  /// validates, collects, or escrows. Shape-validated (name@bank) at input, never
  /// resolution-checked. Handoff primitive for the coming broadcast engine.
  upiVpa            String?
  billingProfiles BillingProfile[]
  cartItems       CartItem[]
  orders          Order[]
  pinnedByUsers   PinnedStore[]
  sections        StoreSection[]
  blocks          StoreBlock[]
  owner           User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  banners         StoreBanner[]
  filters         StoreFilter[]
  images          StoreImage[]
  wishlistItems   WishlistItem[]
  categories      StoreCategoryLink[]
  tags            StoreTagLink[]
  requestResponses RequestResponse[]

  @@index([ownerId])
}

model StoreImage {
  id           String   @id @default(cuid())
  storeId      String
  cloudinaryId String?
  fileHash     String
  fileName     String?
  uploadedAt   DateTime @default(now())
  url          String
  store        Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, fileHash])
  @@index([storeId])
}

model StoreSection {
  id          String               @id @default(cuid())
  storeId     String
  title       String
  order       Int                  @default(0)
  type        String               @default("grid")
  createdAt   DateTime             @default(now())
  prereqIds   String[]             @default([])
  sectionType String               @default("product")
  columns     Int                  @default(5)
  rows        Int                  @default(2)
  rowIndex    Int                  @default(0)
  blocks      StoreBlock[]
  store       Store                @relation(fields: [storeId], references: [id], onDelete: Cascade)
  tiles       SectionTile[]
  filterLinks StoreSectionFilter[]
  subsections StoreSubsection[]

  @@index([storeId])
  @@index([order])
  @@map("Section")
}

model SectionTile {
  id        String       @id @default(cuid())
  sectionId String
  imageUrl  String?
  imageKey  String?
  label     String
  order     Int          @default(0)
  createdAt DateTime     @default(now())
  section   StoreSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId, order])
}

model StoreFilter {
  id        String               @id @default(cuid())
  storeId   String
  name      String
  order     Int                  @default(0)
  bannerId  String?
  createdAt DateTime             @default(now())
  banner    StoreBanner?         @relation(fields: [bannerId], references: [id])
  store     Store                @relation(fields: [storeId], references: [id], onDelete: Cascade)
  sections  StoreSectionFilter[]

  @@index([storeId, order])
}

model StoreBanner {
  id         String        @id @default(cuid())
  storeId    String
  isGlobal   Boolean       @default(false)
  imageUrl   String?
  imageKey   String?
  heading    String?
  subheading String?
  body       String?
  createdAt  DateTime      @default(now())
  store      Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  filters    StoreFilter[]

  @@index([storeId])
}

model StoreSectionFilter {
  sectionId String
  filterId  String
  filter    StoreFilter  @relation(fields: [filterId], references: [id], onDelete: Cascade)
  section   StoreSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@id([sectionId, filterId])
  @@index([filterId])
}

model StoreSubsection {
  id        String       @id @default(cuid())
  sectionId String
  title     String
  order     Int          @default(0)
  createdAt DateTime     @default(now())
  blocks    StoreBlock[]
  section   StoreSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId])
  @@index([order])
  @@map("Subsection")
}

model StoreBlock {
  id             String           @id @default(cuid())
  sectionId      String?
  subsectionId   String?
  /// Denormalized FK — query shortcut; section→store is the source of truth for hierarchy
  storeId        String?
  title          String
  description    String?
  mediaType      String           @default("image")
  mediaUrl       String?
  actionType     String           @default("view")
  price          Float?
  /// Physical weight in kg — used for per-kg delivery cost calculation
  weight         Float            @default(1)
  order          Int              @default(0)
  createdAt      DateTime         @default(now())
  aspect         String?
  blockStatus    String           @default("locked")
  lessonType     String?
  mastery        Int              @default(0)
  lessonTags     String[]         @default([])
  access         String           @default("free")
  visibility     String           @default("public")
  pricingModel   String?
  perKmRate      Float?
  perKgRate      Float?
  assignedUserId String?
  vehicleType    String?
  maxWeightKg    Float?
  maxDistanceKm  Float?
  serviceType    String           @default("product")
  linkedPostId   String?
  imageProvider  String?
  imageQuality   Int              @default(0)
  section        StoreSection?    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  subsection     StoreSubsection? @relation(fields: [subsectionId], references: [id], onDelete: Cascade)
  store          Store?           @relation(fields: [storeId], references: [id], onDelete: SetNull)
  cartItems      CartItem[]
  courseProgress CourseProgress[]
  ratings        ProductRating[]
  wishlistItems  WishlistItem[]

  @@index([sectionId])
  @@index([subsectionId])
  @@index([storeId])
  @@index([order])
  @@map("Block")
}

model CourseProgress {
  id        String     @id @default(cuid())
  userId    String
  blockId   String
  status    String     @default("unlocked")
  mastery   Int        @default(0)
  updatedAt DateTime   @updatedAt
  block     StoreBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, blockId])
  @@index([userId])
  @@index([blockId])
}

model SavedTagSet {
  id        String   @id @default(cuid())
  userId    String
  name      String
  tags      String[]
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// *
/// * Users following pages (one-way)
model PageFollow {
  id        String   @id @default(cuid())
  userId    String
  pageId    String
  createdAt DateTime @default(now())
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, pageId])
  @@index([userId])
  @@index([pageId])
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  token      String   @unique
  expires    DateTime
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([identifier])
}

model Country {
  id          Int          @id @default(autoincrement())
  code        String       @unique
  name        String
  createdAt   DateTime     @default(now())
  adminLevels AdminLevel[]
  regions     Region[]
}

model AdminLevel {
  id        Int     @id @default(autoincrement())
  countryId Int
  level     Int
  label     String
  slug      String?
  country   Country @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@unique([countryId, level])
  @@index([countryId])
}

model Region {
  id              Int              @id @default(autoincrement())
  countryId       Int
  parentId        Int?
  name            String
  code            String?
  level           Int
  population      Int?
  areaSqKm        Float?
  localAreas      LocalArea[]
  country         Country          @relation(fields: [countryId], references: [id], onDelete: Cascade)
  representatives Representative[]

  @@index([countryId])
  @@index([level])
}

model LocalArea {
  id         Int     @id @default(autoincrement())
  regionId   Int
  name       String
  population Int?
  areaWorth  Float?
  assets     Asset[]
  region     Region  @relation(fields: [regionId], references: [id], onDelete: Cascade)

  @@unique([regionId, name])
  @@index([regionId])
}

model Asset {
  id          Int       @id @default(autoincrement())
  localAreaId Int
  name        String
  category    String
  value       Float
  units       String?
  notes       String?
  adminUrl    String?
  localArea   LocalArea @relation(fields: [localAreaId], references: [id], onDelete: Cascade)

  @@index([localAreaId])
}

model Representative {
  id        Int       @id @default(autoincrement())
  regionId  Int
  name      String
  role      String
  party     String?
  startDate DateTime?
  endDate   DateTime?
  contact   String?
  region    Region    @relation(fields: [regionId], references: [id], onDelete: Cascade)

  @@index([regionId])
}

/// Levels represent the five (or more) levels: Personal, Local, National, Global, Universal
model Level {
  id        Int       @id @default(autoincrement())
  key       String    @unique
  name      String
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  tabs      Tab[]
  userTabs  UserTab[]

  @@index([order])
}

/// Canonical Tab (defaults live here). Use is_default to mark defaults
model Tab {
  id           String           @id @default(cuid())
  title        String
  slug         String           @unique
  description  String?
  metadata     Json?
  levelId      Int?
  is_default   Boolean          @default(false)
  is_custom    Boolean          @default(false)
  createdById  String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  category     String?
  tags         Json?
  usageCount   Int              @default(0)
  gridCol      Int?
  gridRow      Int?
  position     Int?
  proposals    Proposal[]       @relation("TabProposals")
  level        Level?           @relation(fields: [levelId], references: [id])
  translations TabTranslation[]
  userTabs     UserTab[]

  @@index([levelId])
  @@index([is_default])
}

model TabTranslation {
  id             String   @id @default(cuid())
  tabId          String
  locale         String
  title          String
  description    String?
  slug           String?
  autoTranslated Boolean  @default(false)
  status         String   @default("needs_review")
  suggestedBy    String?
  reviewedBy     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tab            Tab      @relation(fields: [tabId], references: [id], onDelete: Cascade)

  @@unique([tabId, locale])
  @@index([locale])
  @@index([slug])
}

/// Per-user override / sparse representation (only store diffs)
model UserTab {
  id             String   @id @default(cuid())
  userId         String
  tabId          String?
  levelId        Int?
  defaultSlug    String?
  position       Int?
  visible        Boolean  @default(true)
  customTitle    String?
  customMetadata Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  level          Level?   @relation(fields: [levelId], references: [id], onDelete: Cascade)
  tab            Tab?     @relation(fields: [tabId], references: [id], onDelete: Cascade)
  user           User     @relation("UserUserTabs", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tabId], name: "unique_user_tab")
  @@index([userId])
  @@index([levelId])
}

/// Community proposal for adding/promoting tabs to defaults
model Proposal {
  id          String   @id @default(cuid())
  title       String
  description String?
  proposerId  String
  tabId       String?
  levelId     Int
  status      String   @default("pending")
  tags        Json?
  wordCount   Int?
  language    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  proposer    User     @relation("UserProposals", fields: [proposerId], references: [id], onDelete: Cascade)
  tab         Tab?     @relation("TabProposals", fields: [tabId], references: [id])
  review      Review?
  votes       Vote[]

  @@index([status])
  @@index([levelId])
  @@index([proposerId])
}

/// Votes for proposals (one vote per user per proposal)
model Vote {
  id         String   @id @default(cuid())
  proposalId String
  userId     String
  value      Int
  createdAt  DateTime @default(now())
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  user       User     @relation("UserVotes", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([proposalId, userId])
  @@index([userId])
  @@index([proposalId])
}

/// Admin/moderator review of proposals
model Review {
  id         String   @id @default(cuid())
  proposalId String   @unique
  reviewerId String
  verdict    String
  comment    String?
  createdAt  DateTime @default(now())
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  reviewer   User     @relation("UserReviews", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@index([reviewerId])
}

/// Audit log for critical actions
model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  entity    String
  entityId  String
  data      Json?
  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([entity, entityId])
}

/// Product / usage events for analytics and pipelines
model Event {
  id        String   @id @default(cuid())
  userId    String?
  type      String
  payload   Json?
  levelId   Int?
  tabId     String?
  createdAt DateTime @default(now())
  user      User?    @relation("UserEvents", fields: [userId], references: [id], onDelete: Cascade)

