  @@index([conversationId, createdAt])
  @@index([senderId])
}

/// Server-side backup of decrypted message content, encrypted with a
/// per-user key derived from the server secret.  Used to recover messages
/// when the client's ECDH keypair has rotated and key-history fallback fails.
model ChatMessageBackup {
  id        String   @id @default(cuid())
  userId    String
  messageId String
  encrypted String
  iv        String
  createdAt DateTime @default(now())
  user      User     @relation("UserMsgBackups", fields: [userId], references: [id], onDelete: Cascade)

