/// Order — placed when customer confirms checkout (Cash on Delivery)
model Order {
  id               String    @id @default(cuid())
  userId           String
  storeId          String
  addressId        String
  /// "pending" | "confirmed" | "shipped" | "delivered" | "cancelled"
  status           String    @default("pending")
  total            Float
  /// Snapshot of items: [{ blockId, title, price, quantity, imageUrl }]
  items            Json
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  /// Inline invoice: { legalName, addressLine, city, state, pinCode } — set when user selects Personal or provides ad-hoc details
  invoiceData      Json?
  invoiceGenAt     DateTime?
  invoiceNumber    String?
  invoiceType      String?
  invoiceUrl       String?
  invoiceSignedAt  DateTime?
  invoiceSignedUrl String?
  /// "pending" | "confirmed" | "processing" | "out_for_delivery" | "delivered" | "cancelled"
  deliveryStatus   String    @default("pending")
  /// Collaboration.id — the partner or employee assigned for delivery; null = owner handles delivery themselves
  assignedToId     String?
  /// Optional note from owner to delivery person
  deliveryNote     String?
  /// Vehicle.id of the assigned broadcaster — set by the delivery partner when GPS starts
  vehicleId        String?
  /// null = unassigned | "assigned" = pending partner acceptance | "accepted" = partner ready | "rejected" = partner declined | "completed" = partner delivered
  partnerStatus     String?
  /// Set by the delivery person tapping "Picked up" — switches Navigate from pickup to drop. Never inferred from deliveryStatus/vehicleId (GPS can start before physical pickup).
  pickupConfirmedAt DateTime?
  /// "cod" | "upi" — buyer's chosen payment method at checkout
  paymentMethod     String              @default("cod")
  /// "unpaid" (COD, collect on delivery) | "claimed" (buyer says they paid via UPI, proof attached) | "verified" (owner confirmed receipt). Platform never auto-verifies — manual reconciliation only.
  paymentStatus     String              @default("unpaid")
  /// UPI transaction reference / UTR the buyer pasted as proof
  paymentRef        String?
  /// Cloudinary URL of the payment screenshot the buyer uploaded as proof
  paymentProofUrl   String?
  /// Set to true when a step fails or a quote times out — owner must take action
  requiresAttention Boolean             @default(false)
  /// Ordered array of { quoteId, partyName, amount, status } — set by respond/accept/reorder
  quoteSummary      Json?
  /// Self-relation — sub-orders created per workflow step for the assigned partner
  parentOrderId     String?
  /// "delivery" | "service" | "packaging"
  subOrderType      String?
  /// The agreed fee for this sub-order (quote amount or fixed assignment fee)
  agreedAmount      Float?
  /// Direct employee assignment — User.id of a team member (receiverUserId collab). Mutually exclusive with assignedToId.
  assignedToUserId  String?
  address           Address             @relation(fields: [addressId], references: [id])
  store             Store               @relation(fields: [storeId], references: [id])
  user              User                @relation(fields: [userId], references: [id])
  assignedToUser    User?               @relation("OrderAssignedUser", fields: [assignedToUserId], references: [id])
  quotes            Quote[]
  orderSteps        OrderStepProgress[]
  parentOrder       Order?              @relation("SubOrders", fields: [parentOrderId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  subOrders         Order[]             @relation("SubOrders")

  @@unique([parentOrderId, userId, subOrderType])
  @@index([userId])
  @@index([storeId])
  @@index([createdAt])
  @@index([parentOrderId])
}

/// Wishlist item — toggled per user per product
