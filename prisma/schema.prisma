  createdAt    DateTime              @default(now())
  translations StoreTagTranslation[]
  stores       StoreTagLink[]
}

model StoreTagTranslation {
  id     String   @id @default(cuid())
  tagId  String
  locale String
  title  String
  tag    StoreTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([tagId, locale])
  @@index([locale])
}

model StoreTagLink {
  storeId String
  tagId   String
  store   Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  tag     StoreTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([storeId, tagId])
  @@index([tagId])
