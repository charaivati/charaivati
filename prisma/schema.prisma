generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [uuid_ossp(map: "uuid-ossp", schema: "extensions")]
}

/// ----------------------
/// Existing application models (kept & slightly extended)
/// ----------------------
model User {
  id                      String               @id @default(cuid())
  email                   String?              @unique
  phone                   String?              @unique
  passwordHash            String?
  verified                Boolean              @default(false)
  emailVerified           Boolean              @default(false)
  avatarUrl               String?
  avatarStorageKey        String?
  status                  String               @default("active")
  deletionScheduledAt     DateTime?
  tokenVersion            Int                  @default(0)
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  avatarAt                DateTime?
  name                    String?
  selectedCountry         String?
  lastSelectedLocalAreaId Int?
  shortBio                String?
  title                   String?
  preferredLanguage       String?              @default("en")
  businessIdeas           BusinessIdea[]       @relation("UserBusinessIdeas")
  businessPlans           BusinessPlan[]       @relation("UserBusinessPlans")
  customTabs              CustomTab[]          @relation("UserCustomTabs")
  embeddings              Embedding[]          @relation("UserEmbeddings")
  events                  Event[]              @relation("UserEvents")
  requestsReceived        FriendRequest[]      @relation("req_receiver")
  requestsSent            FriendRequest[]      @relation("req_sender")
  friendshipsA            Friendship[]         @relation("friendA")
  friendshipsB            Friendship[]         @relation("friendB")
  magicLinks              MagicLink[]
  pages                   Page[]               @relation("UserPages")
  pageFollows             PageFollow[]
  profile                 Profile?
  proposals               Proposal[]           @relation("UserProposals")
  reviews                 Review[]             @relation("UserReviews")
  userTabs                UserTab[]            @relation("UserUserTabs")
  verificationTokens      VerificationToken[]
  votes                   Vote[]               @relation("UserVotes")
  posts                   Post[]               @relation("UserPosts")
  circles                 FriendCircle[]       @relation("UserCircles")
  circleMemberships       FriendCircleMember[] @relation("CircleMemberships")
  stores                  Store[]
  expertSubscriptions     ExpertSubscription[]
  courseProgress          CourseProgress[]
  savedTagSets            SavedTagSet[]
  publicKey               UserPublicKey?
  chatConvsA              ChatConversation[]   @relation("ChatConvA")
  chatConvsB              ChatConversation[]   @relation("ChatConvB")
  sentMessages            ChatMessage[]        @relation("ChatSender")
  msgBackups              ChatMessageBackup[]  @relation("UserMsgBackups")
  projectTimelines        ProjectTimeline[]
  aiGoals                 AiGoal[]

  @@index([email])
  @@index([phone])
}

/// *
/// * Friend request (pending -> accepted/rejected)
model FriendRequest {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  message    String?
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  receiver   User     @relation("req_receiver", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User     @relation("req_sender", fields: [senderId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([senderId])
  @@index([receiverId])
}

/// *
/// * Mutual friendship (canonical ordering enforced by application code)
model Friendship {
  id        String   @id @default(cuid())
  userAId   String
  userBId   String
  createdAt DateTime @default(now())
  userA     User     @relation("friendA", fields: [userAId], references: [id], onDelete: Cascade)
  userB     User     @relation("friendB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
}

/// *
/// * Friend circles — named groups of friends (e.g. Family, Close Friends, custom)
model FriendCircle {
  id        String               @id @default(cuid())
  ownerId   String
  label     String
  color     String               @default("blue")
  isDefault Boolean              @default(false)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  owner     User                 @relation("UserCircles", fields: [ownerId], references: [id], onDelete: Cascade)
  members   FriendCircleMember[]

  @@index([ownerId])
}

/// *
/// * Members inside a friend circle
model FriendCircleMember {
  id       String       @id @default(cuid())
  circleId String
  userId   String
  addedAt  DateTime     @default(now())
  circle   FriendCircle @relation(fields: [circleId], references: [id], onDelete: Cascade)
  user     User         @relation("CircleMemberships", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([circleId, userId])
  @@index([circleId])
  @@index([userId])
}

/// *
/// * User profile / health
model Profile {
  id                     String  @id @default(cuid())
  userId                 String  @unique
  heightCm               Int?
  weightKg               Float?
  stepsToday             Int?    @default(0)
  sleepHours             Float?
  waterLitres            Float?
  displayName            String?
  bio                    String?
  socialHandles          Json?
  topics                 Json?
  streakDays             Int?    @default(0)
  learningNotes          String?
  businesses             Json?
  weeklyEarningsEstimate Float?
  desiredMonthlyIncome   Float?  @default(0)
  preferredPayment       String?

  /// SelfTab — purpose layer
  /// Legacy single drive (kept for backward compat)
  drive              String?
  /// Selected drives — DriveType[] e.g. ["learning", "building"]
  drives             Json?
  /// GoalEntry[] — flat array with driveId on each entry
  /// Shape: [{ id, driveId, statement, horizon, skills: [...], linkedBusinessIds, saved }]
  goals              Json?
  /// HealthProfile — stored as JSON
  /// Shape: { food, exercise, sessionsPerWeek, heightCm, weightKg, age }
  /// Note: heightCm / weightKg here are string inputs from the form;
  /// the scalar heightCm / weightKg columns above are the validated numeric store.
  health             Json?
  /// General skills — SkillEntry[] — abilities that apply across all goals
  generalSkills      Json?
  /// Cached AI roadmap — { phases: Phase[], suggestions: Suggestion[] }
  aiPlan             Json?
  /// WeekSchedule — { slots: TimeSlot[], tasks: Task[] }
  weekSchedule       Json?
  /// FundsProfile — income sources, monthly burn, runway target
  fundsProfile       Json?
  /// EnvironmentProfile — city, workspace, constraints, etc.
  environmentProfile Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MagicLink {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  type      String
  expiresAt DateTime
  used      Boolean   @default(false)
  createdAt DateTime  @default(now())
  usedAt    DateTime?
  ip        String?
  meta      Json?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([userId])
}

model Page {
  id               String          @id @default(cuid())
  ownerId          String?
  title            String
  description      String?
  avatarUrl        String?
  avatarStorageKey String?
  status           String          @default("active")
  type             String          @default("standard")
  pageType         String          @default("store")
  viewCount        Int             @default(0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  owner             User?              @relation("UserPages", fields: [ownerId], references: [id])
  followers         PageFollow[]
  healthBusiness    HealthBusiness?
  course            Course?
  helpingInitiative HelpingInitiative?

  @@index([ownerId])
}

model Course {
  id             String   @id @default(cuid())
  pageId         String   @unique
  page           Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  courseType     String   @default("skill")
  dominantAspect String   @default("mental")
  aspectWeights  Json     @default("{\"physical\":33,\"mental\":34,\"emotional\":33}")
  aspectBenefits Json     @default("{}")
  courseTags     String[] @default([])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

/// Universal Store page models (products/videos/services)
model Store {
  id          String         @id @default(cuid())
  name        String
  description String?
  ownerId     String
  pageId      String?        @unique
  createdAt   DateTime       @default(now())
  owner       User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  sections    StoreSection[]
  filters     StoreFilter[]
  banners     StoreBanner[]

  @@index([ownerId])
}

model StoreSection {
  id          String               @id @default(cuid())
  storeId     String
  title       String
  order       Int                  @default(0)
  type        String               @default("grid")
  sectionType String               @default("product")
  columns     Int                  @default(5)
  rows        Int                  @default(2)
  rowIndex    Int                  @default(0)
  prereqIds   String[]             @default([])
  createdAt   DateTime             @default(now())
  store       Store                @relation(fields: [storeId], references: [id], onDelete: Cascade)
  blocks      StoreBlock[]
  subsections StoreSubsection[]
  filterLinks StoreSectionFilter[]
  tiles       SectionTile[]

  @@index([storeId])
  @@index([order])
  @@map("Section")
}

model SectionTile {
  id        String       @id @default(cuid())
  sectionId String
  section   StoreSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  imageUrl  String?
  imageKey  String?
  label     String
  order     Int          @default(0)
  createdAt DateTime     @default(now())

  @@index([sectionId, order])
}

model StoreFilter {
  id        String               @id @default(cuid())
  storeId   String
  name      String
  order     Int                  @default(0)
  bannerId  String?
  createdAt DateTime             @default(now())
  store     Store                @relation(fields: [storeId], references: [id], onDelete: Cascade)
  banner    StoreBanner?         @relation(fields: [bannerId], references: [id])
  sections  StoreSectionFilter[]

  @@index([storeId, order])
}

model StoreBanner {
  id         String        @id @default(cuid())
  storeId    String
  isGlobal   Boolean       @default(false)
  imageUrl   String?
  imageKey   String?
  heading    String?
  subheading String?
  body       String?
  createdAt  DateTime      @default(now())
  store      Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  filters    StoreFilter[]

  @@index([storeId])
}

model StoreSectionFilter {
  sectionId String
  filterId  String
  section   StoreSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  filter    StoreFilter  @relation(fields: [filterId], references: [id], onDelete: Cascade)

  @@id([sectionId, filterId])
  @@index([filterId])
}

model StoreSubsection {
  id        String       @id @default(cuid())
  sectionId String
  title     String
  order     Int          @default(0)
  createdAt DateTime     @default(now())
  section   StoreSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  blocks    StoreBlock[]

  @@index([sectionId])
  @@index([order])
  @@map("Subsection")
}

model StoreBlock {
  id             String           @id @default(cuid())
  sectionId      String?
  subsectionId   String?
  title          String
  description    String?
  mediaType      String           @default("image")
  mediaUrl       String?
  actionType     String           @default("view")
  price          Float?
  order          Int              @default(0)
  aspect         String?
  lessonType     String?
  blockStatus    String           @default("locked")
  mastery        Int              @default(0)
  lessonTags     String[]         @default([])
  access         String           @default("free")
  linkedPostId   String?
  createdAt      DateTime         @default(now())
  section        StoreSection?    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  subsection     StoreSubsection? @relation(fields: [subsectionId], references: [id], onDelete: Cascade)
  courseProgress CourseProgress[]

  @@index([sectionId])
  @@index([subsectionId])
  @@index([order])
  @@map("Block")
}

model CourseProgress {
  id        String     @id @default(cuid())
  userId    String
  blockId   String
  status    String     @default("unlocked")
  mastery   Int        @default(0)
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  block     StoreBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)

  @@unique([userId, blockId])
  @@index([userId])
  @@index([blockId])
}

model SavedTagSet {
  id        String   @id @default(cuid())
  userId    String
  name      String
  tags      String[]
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// *
/// * Users following pages (one-way)
model PageFollow {
  id        String   @id @default(cuid())
  userId    String
  pageId    String
  createdAt DateTime @default(now())
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, pageId])
  @@index([userId])
  @@index([pageId])
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  token      String   @unique
  expires    DateTime
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([identifier])
}

model Country {
  id          Int          @id @default(autoincrement())
  code        String       @unique
  name        String
  createdAt   DateTime     @default(now())
  adminLevels AdminLevel[]
  regions     Region[]
}

model AdminLevel {
  id        Int     @id @default(autoincrement())
  countryId Int
  level     Int
  label     String
  slug      String?
  country   Country @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@unique([countryId, level])
  @@index([countryId])
}

model Region {
  id              Int              @id @default(autoincrement())
  countryId       Int
  parentId        Int?
  name            String
  code            String?
  level           Int
  population      Int?
  areaSqKm        Float?
  localAreas      LocalArea[]
  country         Country          @relation(fields: [countryId], references: [id], onDelete: Cascade)
  representatives Representative[]

  @@index([countryId])
  @@index([level])
}

model LocalArea {
  id         Int     @id @default(autoincrement())
  regionId   Int
  name       String
  population Int?
  areaWorth  Float?
  assets     Asset[]
  region     Region  @relation(fields: [regionId], references: [id], onDelete: Cascade)

  @@unique([regionId, name])
  @@index([regionId])
}

model Asset {
  id          Int       @id @default(autoincrement())
  localAreaId Int
  name        String
  category    String
  value       Float
  units       String?
  notes       String?
  adminUrl    String?
  localArea   LocalArea @relation(fields: [localAreaId], references: [id], onDelete: Cascade)

  @@index([localAreaId])
}

model Representative {
  id        Int       @id @default(autoincrement())
  regionId  Int
  name      String
  role      String
  party     String?
  startDate DateTime?
  endDate   DateTime?
  contact   String?
  region    Region    @relation(fields: [regionId], references: [id], onDelete: Cascade)

  @@index([regionId])
}

/// Levels represent the five (or more) levels: Personal, Local, National, Global, Universal
model Level {
  id        Int       @id @default(autoincrement())
  key       String    @unique
  name      String
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  tabs      Tab[]
  userTabs  UserTab[]

  @@index([order])
}

/// Canonical Tab (defaults live here). Use is_default to mark defaults
model Tab {
  id           String           @id @default(cuid())
  title        String
  slug         String           @unique
  description  String?
  metadata     Json?
  levelId      Int?
  is_default   Boolean          @default(false)
  is_custom    Boolean          @default(false)
  createdById  String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  category     String?
  tags         Json?
  usageCount   Int              @default(0)
  gridCol      Int?
  gridRow      Int?
  position     Int?
  proposals    Proposal[]       @relation("TabProposals")
  level        Level?           @relation(fields: [levelId], references: [id])
  translations TabTranslation[]
  userTabs     UserTab[]

  @@index([levelId])
  @@index([is_default])
}

model TabTranslation {
  id             String   @id @default(cuid())
  tabId          String
  locale         String
  title          String
  description    String?
  slug           String?
  autoTranslated Boolean  @default(false)
  status         String   @default("needs_review")
  suggestedBy    String?
  reviewedBy     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tab            Tab      @relation(fields: [tabId], references: [id], onDelete: Cascade)

  @@unique([tabId, locale])
  @@index([locale])
  @@index([slug])
}

/// Per-user override / sparse representation (only store diffs)
model UserTab {
  id             String   @id @default(cuid())
  userId         String
  tabId          String?
  levelId        Int?
  defaultSlug    String?
  position       Int?
  visible        Boolean  @default(true)
  customTitle    String?
  customMetadata Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  level          Level?   @relation(fields: [levelId], references: [id], onDelete: Cascade)
  tab            Tab?     @relation(fields: [tabId], references: [id], onDelete: Cascade)
  user           User     @relation("UserUserTabs", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tabId], name: "unique_user_tab")
  @@index([userId])
  @@index([levelId])
}

/// Community proposal for adding/promoting tabs to defaults
model Proposal {
  id          String   @id @default(cuid())
  title       String
  description String?
  proposerId  String
  tabId       String?
  levelId     Int
  status      String   @default("pending")
  tags        Json?
  wordCount   Int?
  language    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  proposer    User     @relation("UserProposals", fields: [proposerId], references: [id], onDelete: Cascade)
  tab         Tab?     @relation("TabProposals", fields: [tabId], references: [id])
  review      Review?
  votes       Vote[]

  @@index([status])
  @@index([levelId])
  @@index([proposerId])
}

/// Votes for proposals (one vote per user per proposal)
model Vote {
  id         String   @id @default(cuid())
  proposalId String
  userId     String
  value      Int
  createdAt  DateTime @default(now())
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  user       User     @relation("UserVotes", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([proposalId, userId])
  @@index([userId])
  @@index([proposalId])
}

/// Admin/moderator review of proposals
model Review {
  id         String   @id @default(cuid())
  proposalId String   @unique
  reviewerId String
  verdict    String
  comment    String?
  createdAt  DateTime @default(now())
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  reviewer   User     @relation("UserReviews", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@index([reviewerId])
}

/// Audit log for critical actions
model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  entity    String
  entityId  String
  data      Json?
  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([entity, entityId])
}

/// Product / usage events for analytics and pipelines
model Event {
  id        String   @id @default(cuid())
  userId    String?
  type      String
  payload   Json?
  levelId   Int?
  tabId     String?
  createdAt DateTime @default(now())
  user      User?    @relation("UserEvents", fields: [userId], references: [id], onDelete: Cascade)

  @@index([type])
  @@index([userId])
  @@index([createdAt])
  @@index([levelId])
}

/// Embeddings for semantic search / vector DB reference
model Embedding {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  model      String
  dimension  Int
  vector     Bytes
  vectorRef  String?
  userId     String?
  createdAt  DateTime @default(now())
  user       User?    @relation("UserEmbeddings", fields: [userId], references: [id], onDelete: Cascade)

  @@index([entityType])
  @@index([entityId])
  @@index([userId])
}

/// Optional: user-created custom tabs (if you want to persist custom tabs separate from global Tab)
model CustomTab {
  id          String   @id @default(cuid())
  userId      String
  title       String
  slug        String   @unique
  description String?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation("UserCustomTabs", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Small model for languages (seed uses this)
model Language {
  name       String   @unique
  nativeName String?
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  id         Int      @id @default(autoincrement())
  updatedAt  DateTime @default(now()) @updatedAt
  code       String?  @unique

  @@index([enabled])
  @@index([name])
}

model FeatureFlag {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  enabled   Boolean  @default(false)
  meta      Json?
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz(6)
}

model BusinessPlan {
  id             String    @id @default(uuid())
  title          String
  ownerEmail     String?
  ownerPhone     String?
  ownerUserId    String?
  ownerVerified  Boolean   @default(false)
  retrievalToken String    @unique
  dataJson       Json
  pdfPath        String?
  status         String    @default("draft")
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  expiresAt      DateTime?
  ownerUser      User?     @relation("UserBusinessPlans", fields: [ownerUserId], references: [id])

  @@index([ownerEmail])
  @@index([ownerPhone])
  @@index([createdAt])
  @@index([ownerUserId])
}

model Otp {
  id         String   @id @default(uuid())
  target     String
  targetType String
  codeHash   String
  codeSalt   String?
  attempts   Int      @default(0)
  used       Boolean  @default(false)
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([target])
  @@index([targetType])
  @@index([expiresAt])
}

model BusinessIdea {
  id             String         @id @default(uuid())
  title          String
  description    String
  userEmail      String?
  userPhone      String?
  userId         String?
  problemClarity Int            @default(0)
  marketNeed     Int            @default(0)
  targetAudience Int            @default(0)
  uniqueValue    Int            @default(0)
  feasibility    Int            @default(0)
  monetization   Int            @default(0)
  responses      Json
  status         String         @default("draft")
  shareToken     String?        @unique
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  expiresAt      DateTime?
  businessPlanId String?
  user           User?          @relation("UserBusinessIdeas", fields: [userId], references: [id])
  ideaResponses  IdeaResponse[] @relation("IdeaResponses")

  @@index([userEmail])
  @@index([userId])
  @@index([status])
}

model IdeaQuestion {
  id               String   @id @default(uuid())
  order            Int
  text             String
  type             String
  category         String
  scoringDim       String
  options          Json?
  randomizeOptions Boolean  @default(true)
  dependsOn        String?
  dependsOnValue   String?
  helpText         String?
  examples         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([order])
  @@index([category])
}

model IdeaResponse {
  id         String       @id @default(uuid())
  ideaId     String
  questionId String
  answer     String
  score      Int?
  feedback   String?
  createdAt  DateTime     @default(now())
  idea       BusinessIdea @relation("IdeaResponses", fields: [ideaId], references: [id], onDelete: Cascade)

  @@unique([ideaId, questionId])
  @@index([ideaId])
}

model Post {
  id      String  @id @default(cuid())
  userId  String
  pageId  String?
  content String?

  // Media - Google Drive file IDs (legacy)
  imageFileIds String[] // Array of GDrive file IDs
  videoFileId  String? // Single GDrive file ID

  // Media - Cloudinary CDN URLs
  imageUrls String[] @default([]) // Cloudinary https:// URLs
  videoUrl  String? // Cloudinary https:// URL

  youtubeLinks String[] // YouTube URLs

  // Tagging
  slugTags String[] // ["epfo-login", "hindi", "video"]

  // Engagement - anonymous voting
  likes    Int @default(0)
  dislikes Int @default(0)

  // Metadata
  gdriveFolder String? // Parent folder ID
  status       String  @default("active") // active, hidden
  visibility   String  @default("public") // public, friends, private

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation("UserPosts", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([pageId])
  @@index([createdAt])
  @@index([slugTags])
}

/// ECDH public key for end-to-end encrypted chat
model UserPublicKey {
  id        String   @id @default(cuid())
  userId    String   @unique
  publicKey String // JWK JSON string (ECDH P-256)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Direct message conversation between two users
model ChatConversation {
  id            String        @id @default(cuid())
  userAId       String // canonical: smaller id
  userBId       String // canonical: larger id
  createdAt     DateTime      @default(now())
  lastMessageAt DateTime?
  userA         User          @relation("ChatConvA", fields: [userAId], references: [id], onDelete: Cascade)
  userB         User          @relation("ChatConvB", fields: [userBId], references: [id], onDelete: Cascade)
  messages      ChatMessage[]

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
  @@index([lastMessageAt])
}

/// End-to-end encrypted message — server stores ciphertext only
model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  senderId       String
  ciphertext     String // base64 AES-GCM encrypted content
  iv             String // base64 initialization vector
  createdAt      DateTime         @default(now())
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User             @relation("ChatSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
}

/// Server-side backup of decrypted message content, encrypted with a
/// per-user key derived from the server secret.  Used to recover messages
/// when the client's ECDH keypair has rotated and key-history fallback fails.
model ChatMessageBackup {
  id        String   @id @default(cuid())
  userId    String
  messageId String // ChatMessage.id — not a FK so deleting the message doesn't cascade
  encrypted String // base64 AES-256-GCM ciphertext (server-side key)
  iv        String // base64 IV
  createdAt DateTime @default(now())

  user User @relation("UserMsgBackups", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, messageId])
  @@index([userId, messageId])
}

model HelpLink {
  id        String   @id @default(cuid())
  pageSlug  String? // optional canonical page slug (e.g. "epfo")
  slugTags  String[] @default([]) // tag this link to one or more tab slugs (canonical Tab.slug)
  country   String // e.g. "India", "All"
  title     String // friendly title (page name)
  url       String
  notes     String? // optional internal notes
  createdBy String? // user id who created
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pageSlug])
  @@index([country])
}

/// Project timeline — converts a goal (stored in Profile.goals JSON) into a structured project
model ProjectTimeline {
  id          String    @id @default(cuid())
  userId      String
  /// References a goal id within Profile.goals JSON array (no FK — goals live in JSON)
  goalId      String?
  title       String
  description String?
  /// "product" | "service" | "health" | "relationship" | "custom"
  domain      String
  /// slug of the template used, e.g. "product-development"
  templateId  String?
  isLifelong  Boolean   @default(false)
  startDate   DateTime?
  targetDate  DateTime?
  /// "active" | "paused" | "completed" | "archived"
  status      String    @default("active")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  phases TimelinePhase[]

  @@index([userId, status])
}

model TimelinePhase {
  id          String    @id @default(cuid())
  timelineId  String
  title       String
  description String?
  /// template phase key, e.g. "feasibility"
  phaseKey    String
  order       Int
  /// "pending" | "in_progress" | "completed" | "skipped"
  status      String    @default("pending")
  startDate   DateTime?
  targetDate  DateTime?
  completedAt DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  timeline   ProjectTimeline  @relation(fields: [timelineId], references: [id], onDelete: Cascade)
  milestones PhaseMilestone[]

  @@index([timelineId, order])
}

model PhaseMilestone {
  id          String    @id @default(cuid())
  phaseId     String
  title       String
  isCompleted Boolean   @default(false)
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  phase TimelinePhase @relation(fields: [phaseId], references: [id], onDelete: Cascade)
}

// ─── Goal creation (AI-assisted) ─────────────────────────────────────────────

enum GoalArchetype {
  LEARN
  BUILD
  EXECUTE
  CONNECT
}

enum GoalMode {
  FOCUSED
  ZOOMED_OUT
}

enum GoalStatus {
  DRAFT
  ACTIVE
  ARCHIVED
  COMPLETED
}

model AiGoal {
  id                   String          @id @default(cuid())
  userId               String
  archetype            GoalArchetype
  mode                 GoalMode
  title                String
  whyNow               String?
  commitment           String?
  successSignal        String?
  riskFlags            Json?
  status               GoalStatus      @default(DRAFT)
  executionPlan        Json?
  currentPhaseIndex    Int             @default(0)
  supportingArchetypes GoalArchetype[] @default([])
  answers              AiGoalAnswer[]
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model AiGoalAnswer {
  id           String  @id @default(cuid())
  goalId       String
  questionKey  String
  questionText String
  answer       String  @db.Text
  reflection   String? @db.Text
  tags         Json?
  order        Int

  goal AiGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId, order])
}

// ─── Health Business ──────────────────────────────────────────────────────────

model HealthBusiness {
  id                 String               @id @default(cuid())
  pageId             String               @unique
  specialty          String
  credentials        String?
  consultationMode   String               @default("manual")
  tiers              Json?
  agentConfig        Json?
  searchTags         String[]
  createdAt          DateTime             @default(now())
  page               Page                 @relation(fields: [pageId], references: [id], onDelete: Cascade)
  subscriptions      ExpertSubscription[]
  adviceLog          ExpertAdviceLog[]

  @@index([specialty])
}

model ExpertSubscription {
  id                 String          @id @default(cuid())
  userId             String
  healthBusinessId   String
  tier               String
  status             String          @default("active")
  consentGranted     Boolean         @default(false)
  consentTimestamp   DateTime?
  consentFields      Json?
  subscribedAt       DateTime        @default(now())
  user               User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  healthBusiness     HealthBusiness  @relation(fields: [healthBusinessId], references: [id], onDelete: Cascade)

  @@unique([userId, healthBusinessId])
  @@index([userId])
  @@index([healthBusinessId])
}

// ─── Helping Initiative ───────────────────────────────────────────────────────

model HelpingInitiative {
  id              String             @id @default(cuid())
  pageId          String             @unique
  cause           String?
  targetGroup     String?
  location        String?
  awarenessText   String?
  acceptDonations Boolean            @default(false)
  donationMessage String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  page            Page               @relation(fields: [pageId], references: [id], onDelete: Cascade)
  objectives      HelpingObjective[]
  metrics         HelpingMetric[]
}

model HelpingObjective {
  id           String            @id @default(cuid())
  initiativeId String
  title        String
  order        Int               @default(0)
  createdAt    DateTime          @default(now())
  initiative   HelpingInitiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  actions      HelpingAction[]

  @@index([initiativeId, order])
}

model HelpingAction {
  id          String           @id @default(cuid())
  objectiveId String
  title       String
  order       Int              @default(0)
  createdAt   DateTime         @default(now())
  objective   HelpingObjective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)

  @@index([objectiveId, order])
}

model HelpingMetric {
  id            String            @id @default(cuid())
  initiativeId  String
  label         String
  targetNumber  Float             @default(0)
  currentNumber Float             @default(0)
  unit          String?
  createdAt     DateTime          @default(now())
  initiative    HelpingInitiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)

  @@index([initiativeId])
}

model ExpertAdviceLog {
  id                  String          @id @default(cuid())
  healthBusinessId    String
  userId              String
  userStateSnapshot   Json
  advice              String
  adviceType          String
  deliveredBy         String          @default("manual")
  outcomeSnapshot     Json?
  outcomeTrackedAt    DateTime?
  createdAt           DateTime        @default(now())
  healthBusiness      HealthBusiness  @relation(fields: [healthBusinessId], references: [id], onDelete: Cascade)

  @@index([healthBusinessId])
  @@index([userId])
  @@index([createdAt])
}

model Vehicle {
  id          String   @id
  busNumber   String   @map("bus_number")
  route       String?
  vehicleType String   @default("Bus") @map("vehicle_type")
  lat         Float
  lng         Float
  accuracy    Int?
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("vehicles")
}