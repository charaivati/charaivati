  id            String        @id @default(cuid())
  userAId       String
  userBId       String
  createdAt     DateTime      @default(now())
  lastMessageAt DateTime?
  userA         User          @relation("ChatConvA", fields: [userAId], references: [id], onDelete: Cascade)
  userB         User          @relation("ChatConvB", fields: [userBId], references: [id], onDelete: Cascade)
  messages      ChatMessage[]

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
  @@index([lastMessageAt])
}

/// End-to-end encrypted message — server stores ciphertext only
model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  senderId       String
  ciphertext     String
  iv             String
  createdAt      DateTime         @default(now())
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
