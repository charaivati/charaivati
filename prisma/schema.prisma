model CommunityMembership {
  id            String          @id @default(cuid())
  groupId       String
  group         CommunityGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  memberUserId  String?
  memberUser    User?           @relation("UserMemberships", fields: [memberUserId], references: [id], onDelete: Cascade)
  memberGroupId String?
  memberGroup   CommunityGroup? @relation("SubGroupMemberships", fields: [memberGroupId], references: [id], onDelete: Cascade)
  status        String          @default("pending")
  requestedAt   DateTime        @default(now())
  resolvedAt    DateTime?

  @@unique([groupId, memberUserId])
  @@unique([groupId, memberGroupId])
  @@index([groupId])
}

model CommunityMilestone {
  id        String         @id @default(cuid())
  groupId   String
  group     CommunityGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  title     String
  status    String         @default("pending")
  createdAt DateTime       @default(now())

  @@index([groupId])
}

model CommunityMeeting {
  id        String         @id @default(cuid())
  groupId   String
  group     CommunityGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  title     String
  date      DateTime
  location  String?
  link      String?
  createdAt DateTime       @default(now())

  @@index([groupId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  /// "order_assigned" | "quote_requested" | "quote_submitted" | "step_confirmed" | "order_confirmed" | "delivery_complete"
  type      String
  title     String
  body      String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model WorkflowStep {
  id                String               @id @default(cuid())
  initiativeId      String
  name              String
  sequence          Int
  /// "team_member" | "third_party"
  assigneeType      String
  /// @deprecated — use WorkflowStepAssignee rows instead; kept for existing data
  assigneeId        String?
  /// @deprecated — use WorkflowStepAssignee rows instead; kept for existing data
  assigneeIds       String[]             @default([])
  quoteRequired     Boolean              @default(false)
  quoteTimeoutHours Int                  @default(24)
  /// "sequential" | "first_to_accept"
  assignmentMode    String               @default("sequential")
  /// "normal" | "delivery"
  activityType      String               @default("normal")
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  quotes            Quote[]
  orderSteps        OrderStepProgress[]
  assignees         WorkflowStepAssignee[]

  @@index([initiativeId, sequence])
}

model Quote {
  id               String       @id @default(cuid())
  orderId          String
  stepId           String
  /// Collaboration.id of the party being quoted
  requestedPartyId String
  amount           Float?
  /// "pending" | "submitted" | "accepted" | "rejected"
  status           String       @default("pending")
  expiresAt        DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  step             WorkflowStep @relation(fields: [stepId], references: [id])
  order            Order        @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([stepId])
  @@index([status])
}

model OrderStepProgress {
  id                 String       @id @default(cuid())
  orderId            String
  stepId             String
  /// "pending" | "active" | "confirmed" | "failed"
  status             String       @default("pending")
  activatedAt        DateTime?
  confirmedAt        DateTime?
  /// WorkflowStepAssignee.id currently being tried in the sequential/first_to_accept cycle
  currentAssigneeId  String?
  /// How many full rejection cycles have been completed for this step
  cycleCount         Int          @default(0)
  /// Fee multiplier applied to the current assignee's cost (1.0 = original, 1.05 = 5% hike)
  lastFeeMultiplier  Float        @default(1.0)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  step               WorkflowStep @relation(fields: [stepId], references: [id])
  order              Order        @relation(fields: [orderId], references: [id])

  @@unique([orderId, stepId])
  @@index([orderId])
  @@index([stepId])
}

model WorkflowStepAssignee {
  id               String        @id @default(cuid())
  stepId           String
  collaborationId  String
  sequence         Int
  costPerOrder     Float?
  costPerKg        Float?
  costPerKgPerKm   Float?
  costPerItemPerKm Float?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  step          WorkflowStep  @relation(fields: [stepId], references: [id], onDelete: Cascade)
  collaboration Collaboration @relation(fields: [collaborationId], references: [id], onDelete: Cascade)

  @@unique([stepId, collaborationId])
  @@index([stepId, sequence])
}

