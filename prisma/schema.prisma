model GuardrailEvent {
  id             String   @id @default(cuid())
  userId         String?
  sessionId      String?
  /// INPUT_BLOCKED | INPUT_WARNED | OUTPUT_BLOCKED
  eventType      String
  userMessage    String   @db.Text
  reason         String
  matchedPattern String
