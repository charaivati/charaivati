model InitiativeTransfer {
  id              String    @id @default(cuid())
  pageId          String
  fromUserId      String
  toEmail         String
  toUserId        String?
  status          String    @default("otp_pending")
  // status values: otp_pending | awaiting_recipient | completed | revoked | cancelled
  otpHash         String?
  otpSalt         String?
  otpExpiresAt    DateTime?
  otpAttempts     Int       @default(0)
  recipientToken  String?   @unique
  recipientExpiry DateTime?
  completedAt     DateTime?
  revokeDeadline  DateTime?
  revokedAt       DateTime?
  createdAt       DateTime  @default(now())
  page            Page      @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
  @@index([fromUserId])
}

// Admin-editable override for an ai-context/*.txt file. When a row exists, its
// `body` (full file text) wins over the bundled file in lib/ai/contextLoader.ts.
// Empty table => loader behaves exactly as before (files win). See /admin/context.
model AiContextFile {
  fileName  String   @id
  body      String   @db.Text
  updatedAt DateTime @updatedAt
}

// Compiled per-user context doc, written by a periodic reviewer (cron +
// opportunistic). `kind` keys the lens ("profile-review" now; security/etc.
// later — same table). `body` = human-readable markdown; `meta` = structured
// facets for programmatic consumers. Read/written via raw SQL until generate.
model UserContext {
  userId    String
  kind      String
  body      String   @db.Text
  meta      Json?
  updatedAt DateTime @updatedAt

  @@id([userId, kind])
}

/// Civic layer (CIVIC-1) — geographic membership unit.
/// type: ward | panchayat | assembly | state | country — validated in API, not DB
/// (freq/assumptionKey precedent). Self-relation parentId builds the chain
/// ward/panchayat → assembly → state → country.
model Unit {
  id        String   @id @default(cuid())
  type      String
  name      String
  parentId  String?
  createdAt DateTime @default(now())
  parent    Unit?    @relation("UnitParent", fields: [parentId], references: [id])
  children  Unit[]   @relation("UnitParent")
  residents User[]   @relation("UserHomeUnit")
  issues    Issue[]

  @@index([parentId])
  @@index([type])
}

/// Civic issue — a local demand raised by a resident of a Unit.
/// status lifecycle: proposed → active (ACTIVATION_THRESHOLD supporters) →
/// complete (N confirmations, Prompt 3) | archived. scope: ward | assembly |
/// nation | earth (derived from unit type). category is AI-classified later.
model Issue {
  id             String              @id @default(cuid())
  unitId         String
  authorId       String
  title          String
  body           String              @db.Text
  scope          String              @default("ward")
  status         String              @default("proposed")
  category       String?
  supporterCount Int                 @default(0)
  resolvedAt     DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  unit           Unit                @relation(fields: [unitId], references: [id], onDelete: Cascade)
  author         User                @relation("UserIssues", fields: [authorId], references: [id], onDelete: Cascade)
  supports       IssueSupport[]
  confirmations  IssueConfirmation[]

  @@index([unitId, status])
  @@index([unitId, supporterCount])
}

/// One upvote per resident per issue. supporterCount on Issue is the
/// denormalized counter, kept in the same transaction as row create/delete.
model IssueSupport {
  id        String   @id @default(cuid())
  issueId   String
  userId    String
  createdAt DateTime @default(now())
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  user      User     @relation("UserIssueSupports", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, issueId])
  @@index([issueId])
}

/// Completion confirmation (Prompt 3 flow) — an issue moves to complete only
/// after N supporter confirmations, optionally with a photo. Model created in
/// CIVIC-1 so the migration ships once.
model IssueConfirmation {
  id        String   @id @default(cuid())
  issueId   String
  userId    String
  photoUrl  String?
  createdAt DateTime @default(now())
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  user      User     @relation("UserIssueConfirmations", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, issueId])
  @@index([issueId])
}
