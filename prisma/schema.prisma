  createdAt      DateTime @default(now())

  @@index([eventType])
  @@index([createdAt])
}

/// Email friend-invite — one row per invite sent. Shell user created on send; claimed on link click.
model Invite {
  id            String    @id @default(cuid())
  /// SHA-256(rawToken) — raw token is in the invite email URL only, never stored
  tokenHash     String    @unique
  /// Normalized email (trim + lowercase) of the invited person
  email         String
  /// User.id of the person who sent the invite
  inviterId     String
  /// User.id of the shell user created for the invited email (null until created)
  shellUserId   String?
  /// User.id filled once the invite is claimed
  claimedUserId String?   @unique
  /// "pending" | "claimed" | "expired" | "revoked"
  status        String    @default("pending")
  /// Number of failed claim attempts (bad token, timing attack guard)
  attempts      Int       @default(0)
  expiresAt     DateTime
  claimedAt     DateTime?
  createdAt     DateTime  @default(now())
  inviter       User      @relation("InviteSender", fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([email, status])
  @@index([inviterId])
}

/// Self-tab todo / validation task — one list, two filtered views (BIZDOC-4)
model Todo {
  id               String        @id @default(cuid())
  userId           String
  title            String
  completed        Boolean       @default(false)
  /// Schedule frequency: "daily" | "weekly" | "monthly" (NOT a discriminator — use assumptionKey for that)
  freq             String?
  hobbyId          String?
  /// Links this task to a BusinessIdea — null for general todos
  ideaId           String?
  /// Short label describing the assumption being validated
  validationLabel  String?
  /// What counts as passing validation (e.g. "5 of 10 say yes")
  successThreshold String?
  /// Which market-sizing assumption this validates: "sam" | "som" | null (BIZDOC-5, replaces freq discriminator)
  assumptionKey    String?
  /// CHAKRA-1: which chakra this todo belongs to: root|sacral|solar|heart|throat|third_eye|crown (validated in API, not DB)
  chakra           String?
  /// CHAKRA-1: where the todo came from: manual|validation|execution_plan|initiative (validated in API, not DB)
  source           String?
  createdAt        DateTime      @default(now())
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  idea             BusinessIdea? @relation("IdeaTodos", fields: [ideaId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([ideaId])
}

/// Listener (Saathi) consultation session — one per user, guests included (CONSULT-1b)
model ConsultSession {
  id           String   @id @default(cuid())
  userId       String   @unique
  /// 0 rapport, 1 exploration, 2 values, 3 vision, 4 goal-proposal, 5 handed-off
  consultStage Int      @default(0)
  insights     Json     @default("{}")
  /// Crisis mode latch — set when crisis language is detected; never auto-cleared
  crisisFlag   Boolean  @default(false)
  language     String?
  /// Stable-prefix history (UCTX-1b): condensed summary of folded (oldest) messages
  rollingSummary String? @db.Text
  /// Messages with createdAt <= this are folded into rollingSummary and excluded from the model window
  foldedThrough  DateTime?
  /// FRIEND-NOTIFY-1: last time pending friend requests were surfaced conversationally; null = never
  friendReqSurfacedAt DateTime?
  /// ACTION-INTENT-3: per-user conversational bookkeeping — never merged into insights
  greetedThisSession Boolean   @default(false)
  loginDeclined      Boolean   @default(false)
  loginLastAskedAt   DateTime?
  chatResetAt        DateTime?
  recentIntentNote   String?
  /// ACTION-INTENT-5b: one-turn continuation state for "remind X" with no message yet.
  /// Shape: { recipientName: string, awaitingText: true }. Cleared after the very next turn.
  pendingReminder    Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages     ConsultMessage[]
}

model ConsultMessage {
  id        String   @id @default(cuid())
  sessionId String
  /// "user" | "assistant"
  role      String
  content   String   @db.Text
  createdAt DateTime @default(now())
  session   ConsultSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

/// Listener (Saathi) slow-built personality layer — one per user (UCTX-3).
/// Hypothesis-grade tone-steering signal only. Local-tier composer use only,
/// never sent to cloud providers, never user-facing. NEVER write
/// UserCompanionProfile fields from anything that touches this model
/// (CONSULT-0c §4 standing ban).
model PersonalityProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  /// DISC signal: { D: {score 0-1, evidence: int}, I:..., S:..., C:... }
  disc        Json     @default("{}")
  /// Same shape as disc, keyed by drive: learning/helping/building/doing
  driveScores Json     @default("{}")
  /// Number of extraction passes that have contributed to this profile
  sampleCount Int      @default(0)
  /// 0-1, derived from sampleCount + signal agreement
  confidence  Float    @default(0)
  /// Short evidence strings, capped at 20, FIFO
  notes       Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Admin-taught tone lens for the Listener (PERSONA-1). A persona is a WAY OF
/// THINKING distilled from a conversation with the platform admin/teacher —
/// never a character, never a direct quote, teacher never named. Activated
/// personas are wired into PERSONA-2 (user-facing injection, deferred).
model PhilosophyPersona {
  id          String   @id @default(cuid())
  /// stable key, e.g. "business", "spiritual" — used by PERSONA-2 routing
  name        String   @unique
  displayName String
  /// [SECTION: <name>] ... [/SECTION] format, parsed by contextLoader
  body        String   @db.Text
  /// keywords for PERSONA-2 routing
  triggers    String[] @default([])
  /// draft | active
  status      String   @default("draft")
  /// admin_taught | curated_lens
  sourceType  String   @default("admin_taught")
  /// optional "inspired by ..." note — never a direct quote
  attribution String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// Anonymized knowledge-gap question bridged from a user's Listener session
/// to the admin/teacher (PERSONA-1). Deliberately has NO userId — the admin
/// teaches general knowledge, not user cases.
model AdminQuestion {
  id         String    @id @default(cuid())
  /// user_question | ai_clarification
  source     String
  /// anonymized phrasing — never raw user text with names/places
  question   String    @db.Text
  topic      String?
  /// open | answered | dismissed
  status     String    @default("open")
  answer     String?   @db.Text
  createdAt  DateTime  @default(now())
  answeredAt DateTime?
}

/// Store discovery taxonomy (TAG-STORE-1b) — flat controlled vocabulary,
/// NOT a Prisma enum and NOT related to Page.pageType (initiative type).
/// Categories are a single flat list (no parentId hierarchy).
model StoreCategory {
  id           String                     @id @default(cuid())
  slug         String                     @unique
  order        Int                        @default(0)
  createdAt    DateTime                   @default(now())
  translations StoreCategoryTranslation[]
  stores       StoreCategoryLink[]
  requestBroadcasts RequestBroadcast[]
}

/// RequestBroadcast engine (REQBCAST-1c) — the inDrive/noticeboard primitive.
/// A user posts a service request; nearby providers offering the category get a
/// notification card, respond (optionally with a quoted price), and the requester
/// accepts ONE — then both see contact + UPI VPA to settle DIRECTLY.
/// DOCTRINE: noticeboard, not dispatcher. The platform NEVER assigns, sets the
/// price, or collects/escrows. `status` here is the broadcast's OWN lifecycle —
/// deliberately separate from RequestResponse.status (avoids the OSP "one literal
/// means different things to different readers" footgun).
/// `kind="errand"` fields (pickup/drop/suggestedPrice) are present but DORMANT —
/// errand pickup/drop/pricing logic is a later prompt.
model RequestBroadcast {
  id                 String   @id @default(cuid())
  requesterId        String
  kind               String   @default("service") // "service" | "errand"
  categoryId         String
  title              String
  description        String?
  status             String   @default("open") // "open" | "accepted" | "cancelled" | "expired"
  addressLat         Float?
  addressLng         Float?
  radiusKm           Float    @default(5)
  acceptedResponseId String?  // plain column, no Prisma relation (avoids FK cycle) — resolved manually
  // errand-only (activated REQBCAST-1e). suggestedPrice is a DISPLAY HINT, never enforced.
  pickupLat          Float?
  pickupLng          Float?
  dropLat            Float?
  dropLng            Float?
  pickupLabel        String?
  dropLabel          String?
  suggestedPrice     Float?
  createdAt          DateTime  @default(now())
  expiresAt          DateTime?
  requester          User          @relation("UserRequestBroadcasts", fields: [requesterId], references: [id], onDelete: Cascade)
  category           StoreCategory @relation(fields: [categoryId], references: [id])
  responses          RequestResponse[]

  @@index([status])
  @@index([categoryId])
  @@index([createdAt])
  @@index([addressLat, addressLng])
}

model RequestResponse {
  id              String   @id @default(cuid())
  broadcastId     String
  providerId      String
  providerStoreId String?  // provider may respond as a store or as a user
  quotedPrice     Float?
  message         String?
  status          String   @default("pending") // "pending" | "accepted" | "rejected"
  createdAt       DateTime @default(now())
  broadcast       RequestBroadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  provider        User             @relation("UserRequestResponses", fields: [providerId], references: [id], onDelete: Cascade)
  store           Store?           @relation(fields: [providerStoreId], references: [id], onDelete: SetNull)

  @@unique([broadcastId, providerId]) // one response per provider per broadcast
  @@index([broadcastId])
  @@index([providerId])
}

// FLEET-STATE-1b P1: live foreground location for fleet/runner providers.
// Foreground-only, adaptive, distance-gated, match-on-recent. ADDITIVE to
// eligibility: a fresh available presence is used INSTEAD of Store.lat/lng when
// present (5-min freshness checked at read time), never required.
// mode: "offline" | "available" (P1); "on_job" | "near_complete" in P2.
model ProviderPresence {
  id     String    @id @default(cuid())
  userId String    @unique
  lat    Float?
  lng    Float?
  seenAt DateTime?
  mode   String    @default("offline")
  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([lat, lng])
  @@index([seenAt])
}

model StoreCategoryTranslation {
