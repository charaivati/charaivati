{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "types": ["node"],
    "baseUrl": "."
  },
  "ts-node": {
    "transpileOnly": true
  },
  "include": ["scripts/**/*.ts"],
  "exclude": ["node_modules", ".next"]
}
